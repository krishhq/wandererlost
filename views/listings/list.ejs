<% layout("/layout/boilerplate") %>
<body>
    <h3>List Your Property</h3>
    <h4>Enter Details:</h4>
    <div class="row">
        <div class="col-8 offset-2">
            <form action="/listings/new/" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Property Title:</label>
                    <input name="listing[title]" class="form-control" placeholder="Enter Title" id="title" type="text" required>
                    <div class="valid-feedback">Looks Good!</div>
                </div>
                <br>
                <div class="mb-3">
                    <label for="description" class="form-label">Description:</label>
                    <input name="listing[description]" class="form-control" placeholder="Enter Description" id="description" type="text" required>
                </div>
                <br>
                <div>
                    <label for="img-file" class="form-label">Upload Image:</label>
                    <input name="listing[image]" class="form-control" id="img-file" type="file" required>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price:</label>
                        <input id="price" name="listing[price]" class="form-control" placeholder="Enter Price" required>
                        <div class="invalid-feedback">Enter a valid price</div>
                    </div>
                    <br>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label" >Country:</label>
                        <input id="country" class="form-control" name="listing[country]" placeholder="Enter Country" type="text" required>
                    </div>
                </div>
                <br>
                <div class="mb-3">
                        <label for="location" class="form-label">Location:</label>
                        <input id="location" class="form-control" name="listing[location]" placeholder="Enter Location" type="text" required>
                    </div>
                <br>
                <button>Create</button>
            </form>
        </div>
    </div>
</body>